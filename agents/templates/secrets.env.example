# Copy this to an ignored file such as agents/secrets.env or an agent-specific
# env file. Values should be 1Password secret references, not plaintext secrets.
#
# Run with:
#   op run --env-file agents/secrets.env -- <command>

OPENAI_API_KEY=op://<vault>/<item>/<field>
GOOGLE_API_KEY=op://<vault>/<item>/<field>
ANTHROPIC_API_KEY=op://<vault>/<item>/<field>

DISCORD_BOT_TOKEN=op://<vault>/<item>/<field>
TWILIO_ACCOUNT_SID=op://<vault>/<item>/<field>
TWILIO_AUTH_TOKEN=op://<vault>/<item>/<field>
TWILIO_PHONE_NUMBER=op://<vault>/<item>/<field>
USER_PHONE_NUMBER=op://<vault>/<item>/<field>

RBRAIN_MCP_URL=op://<vault>/<item>/<field>
RBRAIN_MCP_KEY=op://<vault>/<item>/<field>
