node_modules/
bin/
.DS_Store
*.log
.env
.env.*
!.env.*.example
# Bun --compile temp artifacts. Each build emits a new hash-named .bun-build
# file in cwd; glob catches all of them.
*.bun-build
.gstack/
supabase/.temp/
.claude/skills/
.claude/settings.local.json
.obsidian/
.idea
eval/reports/
eval/data/world-v1/world.html

# BrainBench amara-life-v1 Opus cache (regenerate via eval:generate-amara-life)
eval/data/amara-life-v1/_cache/

# claw-test E2E build cache (shim + scratch outputs)
test/.cache/

# Personal / RBrain-specific (Ramy's fork) — keep on disk, never commit
SOUL.md
USER.md
ACCESS_POLICY.md
HEARTBEAT.md
voice-agent/
x-collector/
digests/
.hermes/
.openclaw/
IDENTITY.md
TOOLS.md

# Local agent profiles. Forkers copy agents/templates into these paths, but
# each machine's real agent identity/config stays private.
agents/registry.yaml
agents/*.env
agents/*.env.local
agents/*/SOUL.md
agents/*/IDENTITY.md
agents/*/RUNTIME.md
agents/*/SECRETS.md
agents/*/*.local.md

# Scratch / temp files. Agents sometimes drop these in the repo root by
# accident (observed 2026-04-24 on cole-macbook with .tmp_circleback_mcp.md
# and friends). Block them categorically.
.tmp/
.tmp_*
*.tmp.md
.context/

# Dashboard (Next.js)
dashboard/.next/
dashboard/node_modules/
dashboard/*.tsbuildinfo
dashboard/.vercel/
.next/

# Nested apps (Remotion/Next/etc.) — commit source + lockfiles, never deps/build outputs
apps/*/node_modules/
apps/*/out/
apps/*/dist/
apps/*/build/
apps/*/.env
apps/*/.env.*
!apps/*/.env.*.example

# Auto-managed by gbrain (db_only directories)
media/x/
media/articles/
meetings/transcripts/
# Python local caches
__pycache__/
*.pyc

# Local Book Mirror raw/generated artifacts (private/copyrighted/heavy)
drafts/book-mirror/source-files/
drafts/book-mirror/notebooklm/
drafts/book-mirror/generated/
drafts/book-mirror/*.pdf
drafts/book-mirror/*.mp3
drafts/book-mirror/*.pptx

# Local runtime memory/cache; durable memory belongs in docs/reports/pages
memory/
.claude/
export/

# Tier 3 PGLite snapshot fixture (built on demand by build:pglite-snapshot)
test/fixtures/pglite-snapshot.tar
test/fixtures/pglite-snapshot.version
